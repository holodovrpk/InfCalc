<Window x:Class="InfCalc.Table4Window"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InfCalc"
        mc:Ignorable="d"
        Title="Таблица 4"
        Height="860"
        Width="1750"
        MinHeight="720"
        MinWidth="1450"
        WindowStartupLocation="CenterOwner"
        Background="#EEF4FF">
    <Window.Resources>
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="16"
                          ShadowDepth="2"
                          Opacity="0.15"
                          Color="#000000"/>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="44"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="12">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="MinHeight" Value="42"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsMunicipalityTotalRow}" Value="True">
                    <Setter Property="Background" Value="#F8FAFC"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsGrandTotalRow}" Value="True">
                    <Setter Property="Background" Value="#E0ECFF"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Background="White"
                CornerRadius="24"
                Padding="24"
                Effect="{StaticResource CardShadow}">
            <StackPanel>
                <TextBlock Text="Информация об обучении должностных лиц органов местного самоуправления, осуществляющих управление в сфере образования (органы управления образованием), и образовательных организаций в соответствии с профессиональным стандартом «Специалист по обеспечению АТЗ объекта (территории)», утвержденным приказом Минтруда России от 27 апреля 2023 г. № 374н (Профстандарт)"
                           FontSize="20"
                           FontWeight="Bold"
                           Foreground="#1F2937"
                           TextWrapping="Wrap"/>
                <TextBlock Text="Сводная статистическая таблица"
                           Margin="0,10,0,0"
                           FontSize="14"
                           Foreground="#6B7280"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2"
                Background="White"
                CornerRadius="24"
                Padding="16"
                Effect="{StaticResource CardShadow}">
            <DockPanel LastChildFill="False">
                <Button x:Name="ExportExcelButton"
                        Content="Экспорт в Excel"
                        Width="170"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Click="ExportExcelButton_Click"
                        DockPanel.Dock="Left"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="4"
                Background="White"
                CornerRadius="24"
                Padding="16"
                Effect="{StaticResource CardShadow}">
            <DataGrid x:Name="Table4DataGrid"
                      AutoGenerateColumns="False"
                      HeadersVisibility="Column"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      CanUserResizeRows="False"
                      IsReadOnly="True"
                      SelectionMode="Single"
                      SelectionUnit="FullRow"
                      GridLinesVisibility="All"
                      RowHeaderWidth="0"
                      FontSize="13"
                      Background="White"
                      BorderThickness="0"
                      AlternatingRowBackground="#F8FAFC"
                      RowBackground="White"
                      ColumnHeaderHeight="170"
                      HorizontalScrollBarVisibility="Auto">

                <DataGrid.Resources>
                    <Style TargetType="DataGridColumnHeader">
                        <Setter Property="Background" Value="#E8EEF9"/>
                        <Setter Property="Foreground" Value="#111827"/>
                        <Setter Property="FontWeight" Value="Bold"/>
                        <Setter Property="FontSize" Value="13"/>
                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                        <Setter Property="BorderBrush" Value="#CBD5E1"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding" Value="8"/>
                        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                    </Style>

                    <Style TargetType="DataGridCell">
                        <Setter Property="BorderBrush" Value="#D1D5DB"/>
                        <Setter Property="BorderThickness" Value="1"/>
                        <Setter Property="Padding" Value="6"/>
                        <Setter Property="TextBlock.TextWrapping" Value="Wrap"/>
                        <Setter Property="VerticalContentAlignment" Value="Center"/>
                    </Style>
                </DataGrid.Resources>

                <DataGrid.Columns>
                    <DataGridTemplateColumn Width="220" SortMemberPath="Municipality">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Наименование муниципального образования"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Municipality}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="MunicipalTrained">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц органа управления образованием, обученных в соответствии с Профстандартом"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MunicipalTrained}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="MunicipalPlannedCurrentYear">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц органа управления образованием, обучение которых запланировано в текущем году"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MunicipalPlannedCurrentYear}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="MunicipalPlannedNextYear">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц органа управления образованием, обучение которых запланировано в следующем году"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding MunicipalPlannedNextYear}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="240" SortMemberPath="OrganizationType">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Тип образовательной организации"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OrganizationType}"
                                           TextWrapping="Wrap"
                                           VerticalAlignment="Center"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="120" SortMemberPath="TotalObjects">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Всего объектов (территорий)"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding TotalObjects}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="OrgTrained">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц образовательных организаций, обученных в соответствии с Профстандартом"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OrgTrained}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="OrgPlannedCurrentYear">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц образовательных организаций, обучение которых запланировано в текущем году"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OrgPlannedCurrentYear}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>

                    <DataGridTemplateColumn Width="145" SortMemberPath="OrgPlannedNextYear">
                        <DataGridTemplateColumn.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="Количество должностных лиц образовательных организаций, обучение которых запланировано в следующем году"
                                           TextWrapping="Wrap"
                                           TextAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.HeaderTemplate>
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding OrgPlannedNextYear}"
                                           TextAlignment="Center"
                                           VerticalAlignment="Center"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>