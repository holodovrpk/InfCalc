<Window x:Class="InfCalc.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:InfCalc"
        mc:Ignorable="d"
        Title="Информация о мерах по обеспечению профилактики вооруженных нападений обучающихся на объекты (территории) образовательных организаций"
        Height="760" Width="1300"
        MinHeight="700" MinWidth="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F4F7FB">

    <Window.Resources>

        <!-- Тень -->
        <DropShadowEffect x:Key="CardShadow"
                          BlurRadius="18"
                          ShadowDepth="3"
                          Opacity="0.18"
                          Color="#000000"/>

        <!-- Стиль основной кнопки -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="48"/>
            <Setter Property="Padding" Value="18,8"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="Background" Value="#2563EB"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1D4ED8"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#1E40AF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль кнопок таблиц -->
        <Style x:Key="TableButtonStyle" TargetType="Button">
            <Setter Property="Height" Value="46"/>
            <Setter Property="Width" Value="170"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#1F2937"/>
            <Setter Property="Background" Value="#F8FAFC"/>
            <Setter Property="BorderBrush" Value="#D6E0F5"/>
            <Setter Property="BorderThickness" Value="1.5"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Margin" Value="0,0,12,12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="14">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#E0ECFF"/>
                                <Setter TargetName="border" Property="BorderBrush" Value="#7AA2FF"/>
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="border" Property="Background" Value="#CFE0FF"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="border" Property="Opacity" Value="0.6"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

    </Window.Resources>

    <Grid>
        <!-- Фон -->
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#EEF4FF" Offset="0"/>
                <GradientStop Color="#F8FBFF" Offset="0.5"/>
                <GradientStop Color="#E8F3FF" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>

        <!-- Декоративные круги -->
        <Ellipse Width="280" Height="280"
                 HorizontalAlignment="Right"
                 VerticalAlignment="Top"
                 Margin="0,-90,-80,0"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#90CAF9" Offset="0"/>
                    <GradientStop Color="#0099FF00" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Ellipse Width="220" Height="220"
                 HorizontalAlignment="Left"
                 VerticalAlignment="Bottom"
                 Margin="-60,0,0,-70"
                 IsHitTestVisible="False">
            <Ellipse.Fill>
                <RadialGradientBrush>
                    <GradientStop Color="#A5D6A7" Offset="0"/>
                    <GradientStop Color="#0099FF00" Offset="1"/>
                </RadialGradientBrush>
            </Ellipse.Fill>
        </Ellipse>

        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0"
                    Background="#FFFFFF"
                    CornerRadius="24"
                    Padding="24"
                    Margin="0,0,0,16"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="72"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Width="72" Height="72"
                            CornerRadius="20"
                            Background="#2563EB"
                            VerticalAlignment="Top">
                        <TextBlock Text="📊"
                                   FontSize="34"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Информация о мерах по обеспечению профилактики вооруженных нападений обучающихся на объекты (территории) образовательных организаций"
                                   FontSize="24"
                                   FontWeight="Bold"
                                   Foreground="#1F2937"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Главное окно программы"
                                   Margin="0,10,0,0"
                                   FontSize="14"
                                   Foreground="#6B7280"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Импорт -->
            <Border Grid.Row="1"
                    Background="#FFFFFF"
                    CornerRadius="24"
                    Padding="20"
                    Margin="0,0,0,16"
                    Effect="{StaticResource CardShadow}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Button x:Name="ImportButton"
                            Content="Импортировать JSON"
                            Width="230"
                            Style="{StaticResource PrimaryButtonStyle}"
                            Click="ImportButton_Click"/>

                    <Border Grid.Column="2"
                            Background="#F8FAFC"
                            CornerRadius="14"
                            Padding="14,10"
                            BorderBrush="#E5E7EB"
                            BorderThickness="1">
                        <TextBlock x:Name="FilePathTextBlock"
                                   VerticalAlignment="Center"
                                   FontSize="14"
                                   Foreground="#374151"
                                   Text="Файл не выбран"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>
            </Border>

            <!-- Заголовок блока статистики -->
            <TextBlock Grid.Row="2"
                       Text="Общая статистика"
                       FontSize="20"
                       FontWeight="Bold"
                       Foreground="#1F2937"
                       Margin="4,0,0,12"/>

            <!-- Статистика -->
            <ScrollViewer Grid.Row="3"
                          VerticalScrollBarVisibility="Auto"
                          Background="Transparent">
                <WrapPanel x:Name="StatsPanel" Margin="0,0,0,10">

                    <!-- Всего записей -->
                    <Border Width="245" Height="150"
                            Margin="0,0,16,16"
                            CornerRadius="24"
                            Padding="18"
                            Effect="{StaticResource CardShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#1D4ED8" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Всего записей"
                                       FontSize="16"
                                       Foreground="#DCEBFF"/>
                            <TextBlock x:Name="TotalRecordsTextBlock"
                                       Text="0"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Муниципалитеты -->
                    <Border Width="245" Height="150"
                            Margin="0,0,16,16"
                            CornerRadius="24"
                            Padding="18"
                            Effect="{StaticResource CardShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#10B981" Offset="0"/>
                                <GradientStop Color="#059669" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Муниципальных образований"
                                       FontSize="16"
                                       Foreground="#D9FFF4"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="MunicipalitiesTextBlock"
                                       Text="0"
                                       FontSize="38"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Дошкольные -->
                    <Border Width="300" Height="150"
                            Margin="0,0,16,16"
                            CornerRadius="24"
                            Padding="18"
                            Effect="{StaticResource CardShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#F59E0B" Offset="0"/>
                                <GradientStop Color="#D97706" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Дошкольные образовательные организации"
                                       FontSize="15"
                                       Foreground="#FFF4D6"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="PreschoolTextBlock"
                                       Text="0"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Общеобразовательные -->
                    <Border Width="300" Height="150"
                            Margin="0,0,16,16"
                            CornerRadius="24"
                            Padding="18"
                            Effect="{StaticResource CardShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#8B5CF6" Offset="0"/>
                                <GradientStop Color="#6D28D9" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Общеобразовательные организации"
                                       FontSize="15"
                                       Foreground="#EEE5FF"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="GeneralTextBlock"
                                       Text="0"
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- СПО -->
                    <Border Width="300" Height="150"
                            Margin="0,0,16,16"
                            CornerRadius="24"
                            Padding="18"
                            Effect="{StaticResource CardShadow}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#EC4899" Offset="0"/>
                                <GradientStop Color="#BE185D" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="Образовательные организации СПО"
                                       FontSize="15"
                                       Foreground="#FFE2F1"
                                       TextWrapping="Wrap"/>
                            <TextBlock x:Name="SpoTextBlock"
                                       Text="0" 
                                       FontSize="34"
                                       FontWeight="Bold"
                                       Foreground="White"
                                       Margin="0,14,0,0"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>
            </ScrollViewer>

            <!-- Кнопки таблиц -->
            <Border Grid.Row="4"
                    Background="#FFFFFF"
                    CornerRadius="24"
                    Padding="20"
                    Margin="0,16,0,0"
                    Effect="{StaticResource CardShadow}">
                <StackPanel>
                    <TextBlock Text="Формирование статистических таблиц"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="#1F2937"
                               Margin="0,0,0,16"/>

                    <WrapPanel>
                        <Button x:Name="Table1Button"
                                Content="📄 Таблица 1"
                                Style="{StaticResource TableButtonStyle}"
                                Click="Table1Button_Click"/>

                        <Button x:Name="Table2Button"
                                Content="📄 Таблица 2"
                                Style="{StaticResource TableButtonStyle}"
                                Click="Table2Button_Click"/>

                        <Button x:Name="Table3Button"
                                Content="📄 Таблица 3"
                                Style="{StaticResource TableButtonStyle}"
                                Click="Table3Button_Click"/>

                        <Button x:Name="Table4Button"
                                Content="📄 Таблица 4"
                                Style="{StaticResource TableButtonStyle}"
                                Click="Table4Button_Click"/>

                        <Button x:Name="Table5Button"
                                Content="📄 Таблица 5"
                                Style="{StaticResource TableButtonStyle}"
                                Click="Table5Button_Click"/>
                    </WrapPanel>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>